# RAG Chatbot Configuration
# Copy this file to .env and update values as needed

# Debug mode (true for development)
DEBUG=false

# Model configuration
EMBEDDING_MODEL=all-MiniLM-L12-v2
# LLM backend: "local" (flan-t5, free) or "anthropic" (Claude, requires API credits)
LLM_BACKEND=local
LOCAL_LLM_MODEL=google/flan-t5-base
ANTHROPIC_LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# Vector store persistence directory
VECTOR_STORE_PATH=./data/vector_store

# RAG parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
MAX_TOKENS=512

# Security
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
CORS_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_MB=10
